rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Introduced for Work Order Engine v1.2 (docs/architecture/ADR-002).
    // Not present elsewhere on this branch yet -- the richer role-based
    // rules on feature-dispatch-control-tower (unmerged as of this
    // writing) define similar helpers; reconcile when that branch merges.
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userData().role;
    }

    function isAdminOrDispatcher() {
      return isSignedIn() && (userRole() == "admin" || userRole() == "dispatcher");
    }

    function isTechnician() {
      return isSignedIn() && userRole() == "technician";
    }

    function isOwnTechnician(technicianId) {
      return isSignedIn() && userData().technicianId == technicianId;
    }

    match /fieldops_jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /fieldops_technicians/{techId} {
      allow read, write: if isSignedIn();
    }

    // Role docs are provisioned by an admin (console or Admin SDK), never
    // by the client -- a user must not be able to grant themself a role.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // Phase 3 -- Platform Assignment Foundation (docs/specifications/
    // employee-foundation.md). Employee is the authoritative workforce
    // identity (docs/PROJECT_ARCHITECTURE.md's Person Assignment
    // Platform Service Standard, docs/BusinessEntityModel.md Section 8a)
    // -- separate from users/{uid}'s application-access identity above.
    // Two read paths, not one: (A) admin/dispatcher may read the
    // assignment-eligible Employee directory, same gate as every other
    // Reorder-Request-adjacent collection; (B) any authenticated user
    // (including technician) may read ONLY their own linked Employee --
    // AuthContext must resolve a technician's own Employee identity,
    // which admin/dispatcher-only read could never support. The self-
    // read path reuses userData() (already defined above) rather than a
    // second get() -- userData().employeeId == employeeId denies access
    // outright when users/{uid}.employeeId is null (a valid, expected
    // migration state, not an error) and denies a technician reading
    // any Employee record other than their own linked one. No client,
    // in any role including admin, may create/update/delete an Employee
    // -- linkage is established exclusively by
    // functions/scripts/provisionEmployeeAccess.js (Admin SDK, bypasses
    // these rules by design). Employee Administration UI is explicitly
    // out of scope for this phase; do not loosen this to add one.
    match /employees/{employeeId} {
      allow read: if isAdminOrDispatcher()
        || (isSignedIn() && userData().employeeId == employeeId);
      allow create, update, delete: if false;
    }

    // Work Order Engine v1.2 (docs/architecture/ADR-002). All writes go
    // through the createWorkOrder/transitionWorkOrder Cloud Functions
    // (Admin SDK, bypasses these rules by design) -- clients are
    // read-only here, unconditionally, with NO admin/dispatcher
    // exception: there is no future path for an "admin UI" to grow a
    // direct-write shortcut around the Cloud Functions.
    match /fieldops_wos/{woId} {
      allow read: if isAdminOrDispatcher()
        || (isTechnician() && isOwnTechnician(resource.data.assignedTechId));
      allow create, update, delete: if false;
    }

    match /counters/{counterId} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    // Epic 2D Inventory Trigger System (docs/architecture/ADR-003).
    // Admin-SDK-only writes, same posture as counters above. Read
    // access opened to admin/dispatcher when the Operations dashboard
    // (functions/src/inventoryAnalyticsService.ts's client mirror) was
    // added -- ADR-003 anticipated this exact moment ("no reporting
    // view exists yet"). inventory_sync_status stays fully closed --
    // internal retry/idempotency bookkeeping, no reporting value.
    match /inventory_transactions/{transactionId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /inventory_sync_status/{workOrderId} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    // Sprint 2.1.3 -- Reorder Request & Notification Foundation
    // (docs/BusinessEntityModel.md's Reorder Request entry). Unlike the
    // ledger above, this IS a client-direct-write collection (Inventory
    // Management's domain/inventoryReorderRequests.js, mirroring the
    // accounts/locations/contacts pattern) -- no Cloud Function.
    //
    // Sprint 2.1.4 -- Reorder Review & Decision. Update is now allowed,
    // but narrowly: only via domain/inventoryReorderRequests.js's
    // reviewReorderRequest(). The original request facts (partId,
    // urgency, recommendedQty, requestedBy, createdAt) are immutable --
    // a client cannot rewrite them, and an already-decided request
    // cannot be re-reviewed (resource.data.status must still be
    // PENDING_REVIEW). affectedKeys() further pins the write to exactly
    // the review/ownership fields reviewReorderRequest() sets, so no
    // other field can ride along on the same write even if it happened
    // to match its prior value. This is the only write path for a
    // review decision; there is no Cloud Function for this sprint
    // either.
    //
    // Sprint 2.1.5 -- Inventory -> Parts Manager Handoff. An approval
    // now advances status to READY_FOR_PARTS_MANAGER (not APPROVED)
    // and hands currentOwner to PARTS_MANAGER; reviewDecision still
    // permanently records APPROVED, separately from status. A
    // rejection is terminal (status == REJECTED, reviewDecision ==
    // REJECTED) and leaves currentOwner unchanged (still INVENTORY --
    // there is no further hand-off for a rejected request).
    //
    // Sprint 2.1.6 -- Parts Manager -> Parts Associate Assignment.
    // READY_FOR_PARTS_MANAGER is no longer terminal: a second update
    // path allows READY_FOR_PARTS_MANAGER -> ASSIGNED_TO_PARTS_ASSOCIATE,
    // via domain/inventoryReorderRequests.js's assignReorderRequest().
    // This is the platform's first per-user ownership write --
    // assignedBy is pinned to the caller's own uid (no assigning on
    // someone else's behalf), assignedToUserId must be a non-empty
    // string (the manually-entered target uid; there is no
    // client-side user list to validate against, see
    // firestore.rules' users/{userId} self-only read above), and the
    // review fields (reviewDecision/reviewedBy/reviewedAt/reviewNotes)
    // are pinned unchanged so an assignment can never rewrite review
    // history.
    //
    // Sprint 2.1.7 -- Purchase Execution Foundation. A third update
    // path allows ASSIGNED_TO_PARTS_ASSOCIATE -> PURCHASING_IN_PROGRESS,
    // via domain/inventoryReorderRequests.js's startPurchasing(). This
    // is the platform's first update restricted to one specific
    // individual, not just admin/dispatcher generally:
    // request.auth.uid must equal the request's OWN assignedToUserId
    // (resource.data, not request.resource.data -- the assignee can't
    // reassign it to themselves as part of this write, that field is
    // pinned unchanged below) -- so only the assigned Parts Associate
    // can start purchasing on their own request, not any other
    // admin/dispatcher. currentOwner, all three assignment fields, and
    // all four review fields are pinned unchanged -- this transition
    // never rewrites prior workflow history.
    //
    // Sprint 2.1.8 -- Purchasing Progress Update. A fourth update path
    // allows PURCHASING_IN_PROGRESS -> PURCHASING_IN_PROGRESS (status
    // unchanged -- this is the first branch here that is NOT a
    // transition, via domain/inventoryReorderRequests.js's
    // updatePurchasingProgress()), so the assigned Parts Associate can
    // post any number of progress updates while purchasing is
    // underway. Same per-user restriction as Sprint 2.1.7's branch:
    // request.auth.uid must equal the request's OWN assignedToUserId.
    // currentOwner, all three assignment fields, both purchasing-start
    // fields, and all four review fields are pinned unchanged --
    // deliberately does not create a Purchase Order or Vendor
    // Management record, just informal progress fields on the
    // existing Reorder Request.
    //
    // Sprint 2.1.10 -- Purchase Order Foundation. A fifth update path
    // allows PURCHASING_IN_PROGRESS -> ORDERED, via
    // domain/reorderPurchaseOrders.js's recordPurchaseOrder() -- the
    // ONLY function that ever writes this transition, and it does so
    // in the SAME Firestore transaction as creating the linked
    // reorder_purchase_orders/{requestId} document below, so the two
    // can never drift out of sync (both writes commit together or
    // neither does). purchaseOrderId is pinned to equal this
    // document's own requestId (the Reorder Purchase Order's ID is
    // always its linked Reorder Request's ID -- see that collection's
    // rule for why this also prevents duplicates). Same per-user
    // restriction as Sprints 2.1.7/2.1.8: request.auth.uid must equal
    // the request's OWN assignedToUserId. currentOwner, all three
    // assignment fields, both purchasing-start fields, all five
    // purchasing-update fields, and all four review fields are pinned
    // unchanged -- this transition never rewrites prior workflow
    // history.
    match /reorder_requests/{requestId} {
      allow read: if isAdminOrDispatcher();
      allow create: if isAdminOrDispatcher();
      allow update: if isAdminOrDispatcher()
        && ((resource.data.status == "PENDING_REVIEW"
              && ((request.resource.data.status == "READY_FOR_PARTS_MANAGER"
                    && request.resource.data.reviewDecision == "APPROVED"
                    && request.resource.data.currentOwner == "PARTS_MANAGER")
                  || (request.resource.data.status == "REJECTED"
                    && request.resource.data.reviewDecision == "REJECTED"
                    && request.resource.data.currentOwner == resource.data.currentOwner))
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(["status", "reviewDecision", "reviewedBy", "reviewedAt", "reviewNotes", "currentOwner"])
              && (request.resource.data.status != "REJECTED"
                  || (request.resource.data.reviewNotes is string && request.resource.data.reviewNotes.size() > 0)))
            || (resource.data.status == "READY_FOR_PARTS_MANAGER"
              && request.resource.data.status == "ASSIGNED_TO_PARTS_ASSOCIATE"
              && request.resource.data.currentOwner == "PARTS_ASSOCIATE"
              && request.resource.data.assignedToUserId is string
              && request.resource.data.assignedToUserId.size() > 0
              && request.resource.data.assignedBy == request.auth.uid
              && request.resource.data.assignedAt is number
              && request.resource.data.reviewDecision == resource.data.reviewDecision
              && request.resource.data.reviewedBy == resource.data.reviewedBy
              && request.resource.data.reviewedAt == resource.data.reviewedAt
              && request.resource.data.reviewNotes == resource.data.reviewNotes
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(["status", "currentOwner", "assignedToUserId", "assignedBy", "assignedAt"]))
            || (resource.data.status == "ASSIGNED_TO_PARTS_ASSOCIATE"
              && request.resource.data.status == "PURCHASING_IN_PROGRESS"
              && request.auth.uid == resource.data.assignedToUserId
              && request.resource.data.purchasingStartedBy == request.auth.uid
              && request.resource.data.purchasingStartedAt is number
              && request.resource.data.currentOwner == resource.data.currentOwner
              && request.resource.data.assignedToUserId == resource.data.assignedToUserId
              && request.resource.data.assignedBy == resource.data.assignedBy
              && request.resource.data.assignedAt == resource.data.assignedAt
              && request.resource.data.reviewDecision == resource.data.reviewDecision
              && request.resource.data.reviewedBy == resource.data.reviewedBy
              && request.resource.data.reviewedAt == resource.data.reviewedAt
              && request.resource.data.reviewNotes == resource.data.reviewNotes
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(["status", "purchasingStartedAt", "purchasingStartedBy"]))
            || (resource.data.status == "PURCHASING_IN_PROGRESS"
              && request.resource.data.status == "PURCHASING_IN_PROGRESS"
              && request.auth.uid == resource.data.assignedToUserId
              && request.resource.data.lastPurchasingUpdateBy == request.auth.uid
              && request.resource.data.lastPurchasingUpdateAt is number
              && request.resource.data.currentOwner == resource.data.currentOwner
              && request.resource.data.assignedToUserId == resource.data.assignedToUserId
              && request.resource.data.assignedBy == resource.data.assignedBy
              && request.resource.data.assignedAt == resource.data.assignedAt
              && request.resource.data.purchasingStartedAt == resource.data.purchasingStartedAt
              && request.resource.data.purchasingStartedBy == resource.data.purchasingStartedBy
              && request.resource.data.reviewDecision == resource.data.reviewDecision
              && request.resource.data.reviewedBy == resource.data.reviewedBy
              && request.resource.data.reviewedAt == resource.data.reviewedAt
              && request.resource.data.reviewNotes == resource.data.reviewNotes
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(["purchasingNotes", "vendorContacted", "expectedAvailabilityDate", "lastPurchasingUpdateAt", "lastPurchasingUpdateBy"]))
            || (resource.data.status == "PURCHASING_IN_PROGRESS"
              && request.resource.data.status == "ORDERED"
              && request.auth.uid == resource.data.assignedToUserId
              && request.resource.data.purchaseOrderId == requestId
              && request.resource.data.orderedBy == request.auth.uid
              && request.resource.data.orderedAt is number
              && request.resource.data.currentOwner == resource.data.currentOwner
              && request.resource.data.assignedToUserId == resource.data.assignedToUserId
              && request.resource.data.assignedBy == resource.data.assignedBy
              && request.resource.data.assignedAt == resource.data.assignedAt
              && request.resource.data.purchasingStartedAt == resource.data.purchasingStartedAt
              && request.resource.data.purchasingStartedBy == resource.data.purchasingStartedBy
              && request.resource.data.purchasingNotes == resource.data.purchasingNotes
              && request.resource.data.vendorContacted == resource.data.vendorContacted
              && request.resource.data.expectedAvailabilityDate == resource.data.expectedAvailabilityDate
              && request.resource.data.lastPurchasingUpdateAt == resource.data.lastPurchasingUpdateAt
              && request.resource.data.lastPurchasingUpdateBy == resource.data.lastPurchasingUpdateBy
              && request.resource.data.reviewDecision == resource.data.reviewDecision
              && request.resource.data.reviewedBy == resource.data.reviewedBy
              && request.resource.data.reviewedAt == resource.data.reviewedAt
              && request.resource.data.reviewNotes == resource.data.reviewNotes
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(["status", "purchaseOrderId", "orderedBy", "orderedAt"])
              // Cross-document invariant (ChatGPT PR #77 review): a
              // rules-independent write of THIS transition alone,
              // without the matching reorder_purchase_orders/{requestId}
              // create also landing in the SAME commit, is rejected --
              // getAfter()/existsAfter() read the post-transaction state,
              // so both writes are provably part of one atomic operation,
              // not just independently-valid writes that happened to be
              // sent together.
              && existsAfter(/databases/$(database)/documents/reorder_purchase_orders/$(requestId))
              && getAfter(/databases/$(database)/documents/reorder_purchase_orders/$(requestId)).data.reorderRequestId == requestId
              && getAfter(/databases/$(database)/documents/reorder_purchase_orders/$(requestId)).data.createdBy == request.auth.uid
              && getAfter(/databases/$(database)/documents/reorder_purchase_orders/$(requestId)).data.status == "ORDERED"
              && getAfter(/databases/$(database)/documents/reorder_purchase_orders/$(requestId)).data.partId == resource.data.partId))
        && request.resource.data.partId == resource.data.partId
        && request.resource.data.urgency == resource.data.urgency
        && request.resource.data.recommendedQty == resource.data.recommendedQty
        && request.resource.data.requestedBy == resource.data.requestedBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    // Sprint 2.1.10 -- Purchase Order Foundation. A NEW, separate
    // collection -- deliberately NOT the existing purchase_orders
    // collection below (Epic 5, Procurement + Supplier Management:
    // Admin-SDK-only, Supplier-linked, unrelated to this minimal,
    // Reorder-Request-linked record). Documented as "Reorder Purchase
    // Order" specifically to avoid confusion with that entity -- see
    // docs/BusinessEntityModel.md Section 4b.
    //
    // The document ID is its own linked reorderRequestId (not an
    // auto-generated ID) -- this is what makes "no duplicate Purchase
    // Order per Reorder Request" enforceable by Firestore itself: a
    // second write to the same ID is evaluated as an `update` (since
    // the document already exists), which is denied unconditionally
    // below, not just discouraged by a client-side check.
    //
    // Only the assigned Parts Associate (checked via a get() against
    // the linked reorder_requests document's CURRENT, pre-transaction
    // state) on a request that is currently PURCHASING_IN_PROGRESS may
    // create one -- and only via domain/reorderPurchaseOrders.js's
    // recordPurchaseOrder(), which creates this document AND
    // transitions the linked Reorder Request to ORDERED in the same
    // Firestore transaction, so the two can never drift out of sync.
    //
    // Cross-document invariant (ChatGPT PR #77 review): getAfter() on
    // reorder_requests/{requestId} requires that, after this write's
    // transaction commits, the linked Reorder Request is actually
    // ORDERED with a matching purchaseOrderId/orderedBy/orderedAt --
    // so this document cannot be created without the matching
    // reorder_requests transition landing in the SAME commit. Combined
    // with that transition's own getAfter() check (above), the two
    // writes are provably atomic from the rules' perspective, not just
    // independently-valid writes that happened to arrive together.
    // orderedAt is required to equal this document's own createdAt,
    // since domain/reorderPurchaseOrders.js's recordPurchaseOrder()
    // intentionally stamps both fields with the same `now` value.
    //
    // Field validation: partId must equal the linked Reorder Request's
    // OWN existing partId (not merely "is string") -- a Purchase Order
    // can never claim a different part than the request it's for.
    // keys().hasOnly() pins the write to exactly the fields
    // recordPurchaseOrder() sets, so no extra field can ride along.
    // expectedArrivalDate is optional -- null or a string, never
    // omitted (recordPurchaseOrder() always writes it, as null when
    // not provided).
    match /reorder_purchase_orders/{requestId} {
      allow read: if isAdminOrDispatcher();
      allow create: if isAdminOrDispatcher()
        && request.auth.uid == get(/databases/$(database)/documents/reorder_requests/$(requestId)).data.assignedToUserId
        && get(/databases/$(database)/documents/reorder_requests/$(requestId)).data.status == "PURCHASING_IN_PROGRESS"
        && request.resource.data.keys().hasOnly([
             "reorderRequestId", "partId", "supplierName", "externalPoNumber",
             "orderedQuantity", "orderedDate", "expectedArrivalDate", "status",
             "createdBy", "createdAt"
           ])
        && request.resource.data.reorderRequestId == requestId
        && request.resource.data.partId == get(/databases/$(database)/documents/reorder_requests/$(requestId)).data.partId
        && request.resource.data.supplierName is string
        && request.resource.data.supplierName.size() > 0
        && request.resource.data.externalPoNumber is string
        && request.resource.data.externalPoNumber.size() > 0
        && request.resource.data.orderedQuantity is number
        && request.resource.data.orderedQuantity > 0
        && request.resource.data.orderedDate is string
        && request.resource.data.orderedDate.size() > 0
        && (request.resource.data.expectedArrivalDate == null || request.resource.data.expectedArrivalDate is string)
        && request.resource.data.status == "ORDERED"
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is number
        && existsAfter(/databases/$(database)/documents/reorder_requests/$(requestId))
        && getAfter(/databases/$(database)/documents/reorder_requests/$(requestId)).data.status == "ORDERED"
        && getAfter(/databases/$(database)/documents/reorder_requests/$(requestId)).data.purchaseOrderId == requestId
        && getAfter(/databases/$(database)/documents/reorder_requests/$(requestId)).data.orderedBy == request.auth.uid
        && getAfter(/databases/$(database)/documents/reorder_requests/$(requestId)).data.orderedAt == request.resource.data.createdAt;
      allow update, delete: if false;
    }

    // Sprint 2.1.9 -- Inventory Actions Foundation. A new, separate,
    // append-only audit collection for human-initiated inventory
    // adjustments (Receive Stock/Adjust Stock/Correct Mistake) via
    // domain/inventoryActions.js's recordInventoryAction() -- NOT a
    // modification of inventory_transactions (Epic 2D/3, ADR-003)
    // below, which remains Admin-SDK-only/Work-Order-driven and
    // completely untouched. Mirrors reorder_requests' client-direct-
    // write pattern: no Cloud Function, admin/dispatcher only,
    // create-only -- no update/delete, since correcting a mistake
    // means recording ANOTHER action, never editing history. No field-
    // level validation here (same posture as reorder_requests' create
    // rule) -- validation lives in recordInventoryAction(), the sole
    // write path.
    match /inventory_actions/{actionId} {
      allow read: if isAdminOrDispatcher();
      allow create: if isAdminOrDispatcher();
      allow update, delete: if false;
    }

    // Epic 4 Warehouse + Fulfillment System. Same Admin-SDK-only write
    // posture as the ledger above -- a physical-reality layer, not a
    // second source of truth, so no direct client writes here either.
    // Read access opened to admin/dispatcher for the Operations
    // dashboard, same reasoning as inventory_transactions above.
    match /warehouses/{warehouseId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /stock_locations/{stockLocationId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /transfer_orders/{transferOrderId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    // Epic 5 Procurement + Supplier Management System. Same Admin-SDK-
    // only write posture as the ledger/warehouse collections above --
    // fully internal, no external vendor integration, no client writes.
    // Read access opened to admin/dispatcher for the Operations
    // dashboard, same reasoning as above.
    match /suppliers/{supplierId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /supplier_catalog/{catalogItemId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /purchase_orders/{purchaseOrderId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    // Sprint 2.0.2 -- Customer Foundation (docs/BusinessEntityModel.md).
    // Unlike Work Orders, Accounts/Locations/Contacts have no state
    // machine and no cross-document transactional invariant to
    // protect -- client-direct-write-with-rules, same pipeline shape
    // as fieldops_jobs/fieldops_technicians, not a Cloud Function.
    // No deletion UX exists yet (deactivation is via the `status`
    // field), so delete stays closed rather than added speculatively.
    // Technician read access deliberately NOT granted yet -- see
    // docs/BusinessEntityModel.md's Sprint 2.0.2 implementation plan
    // for the open question this defers (technician-facing screens
    // that display a raw customerId/locationId today keep doing so
    // rather than erroring).
    match /accounts/{accountId} {
      allow read: if isAdminOrDispatcher();
      allow create, update: if isAdminOrDispatcher();
      allow delete: if false;
    }

    match /locations/{locationId} {
      allow read: if isAdminOrDispatcher();
      allow create, update: if isAdminOrDispatcher();
      allow delete: if false;
    }

    match /contacts/{contactId} {
      allow read: if isAdminOrDispatcher();
      allow create, update: if isAdminOrDispatcher();
      allow delete: if false;
    }
  }
}
