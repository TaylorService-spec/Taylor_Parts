rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Introduced for Work Order Engine v1.2 (docs/architecture/ADR-002).
    // Not present elsewhere on this branch yet -- the richer role-based
    // rules on feature-dispatch-control-tower (unmerged as of this
    // writing) define similar helpers; reconcile when that branch merges.
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userData().role;
    }

    function isAdminOrDispatcher() {
      return isSignedIn() && (userRole() == "admin" || userRole() == "dispatcher");
    }

    function isTechnician() {
      return isSignedIn() && userRole() == "technician";
    }

    function isOwnTechnician(technicianId) {
      return isSignedIn() && userData().technicianId == technicianId;
    }

    match /fieldops_jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /fieldops_technicians/{techId} {
      allow read, write: if isSignedIn();
    }

    // Role docs are provisioned by an admin (console or Admin SDK), never
    // by the client -- a user must not be able to grant themself a role.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // Work Order Engine v1.2 (docs/architecture/ADR-002). All writes go
    // through the createWorkOrder/transitionWorkOrder Cloud Functions
    // (Admin SDK, bypasses these rules by design) -- clients are
    // read-only here, unconditionally, with NO admin/dispatcher
    // exception: there is no future path for an "admin UI" to grow a
    // direct-write shortcut around the Cloud Functions.
    match /fieldops_wos/{woId} {
      allow read: if isAdminOrDispatcher()
        || (isTechnician() && isOwnTechnician(resource.data.assignedTechId));
      allow create, update, delete: if false;
    }

    match /counters/{counterId} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    // Epic 2D Inventory Trigger System (docs/architecture/ADR-003).
    // Admin-SDK-only writes, same posture as counters above. Read
    // access opened to admin/dispatcher when the Operations dashboard
    // (functions/src/inventoryAnalyticsService.ts's client mirror) was
    // added -- ADR-003 anticipated this exact moment ("no reporting
    // view exists yet"). inventory_sync_status stays fully closed --
    // internal retry/idempotency bookkeeping, no reporting value.
    match /inventory_transactions/{transactionId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /inventory_sync_status/{workOrderId} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    // Epic 4 Warehouse + Fulfillment System. Same Admin-SDK-only write
    // posture as the ledger above -- a physical-reality layer, not a
    // second source of truth, so no direct client writes here either.
    // Read access opened to admin/dispatcher for the Operations
    // dashboard, same reasoning as inventory_transactions above.
    match /warehouses/{warehouseId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /stock_locations/{stockLocationId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /transfer_orders/{transferOrderId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    // Epic 5 Procurement + Supplier Management System. Same Admin-SDK-
    // only write posture as the ledger/warehouse collections above --
    // fully internal, no external vendor integration, no client writes.
    // Read access opened to admin/dispatcher for the Operations
    // dashboard, same reasoning as above.
    match /suppliers/{supplierId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /supplier_catalog/{catalogItemId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }

    match /purchase_orders/{purchaseOrderId} {
      allow read: if isAdminOrDispatcher();
      allow create, update, delete: if false;
    }
  }
}
