{
  "name": "functions",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth",
    "deploy": "npm run build && firebase deploy --only functions",
    "test:rules": "node scripts/rulesRegressionRunner.mjs",
    "test:runner": "node test/rulesRegressionRunner.test.mjs",
    "test:access": "npm run build && node test/permissionCatalog.test.mjs && node test/resolveEffectivePermission.test.mjs && node test/governedBusinessRoles.test.mjs && node test/shadowParityHarness.test.mjs && node test/compactClaims.test.mjs && node test/compactClaimsMirrorIntegrity.test.mjs",
    "test:audit": "npm run build && node test/auditEventWriter.test.mjs",
    "test:effectiveAccess": "npm run build && node test/effectiveAccessFeed.test.mjs",
    "test:claims": "npm run build && node test/claimsWriter.test.mjs",
    "test:trustedWriter": "npm run build && node test/trustedWriterCommands.test.mjs",
    "test:operatorAccess": "node --test test/operatorAccessCommand.test.js",
    "test:legacyDataAudit": "node --test test/auditLegacyJobTechnicianData.test.js",
    "test:operatorAccessExecute": "npm run build && node --test test/operatorAccessCommandExecute.test.js",
    "test:reporting": "npm run build && node test/reportCatalogParity.test.mjs && node test/reportExecutionService.test.mjs && node test/savedDefinitionCommands.test.mjs",
    "test:transitionEngine": "npm run build && node test/transitionEngine.test.mjs",
    "test:inventoryEffectDetection": "npm run build && node test/inventoryEffectDetection.test.mjs",
    "test:partMasterCommands": "npm run build && node test/partMasterCommands.test.mjs",
    "test:partMasterDomain": "npm run build && node test/partMasterDomain.test.mjs",
    "test:inventoryEffectOperatorTools": "npm run build && node --test test/inventoryEffectOperatorTools.test.js",
    "audit:inventory-effects": "npm run build && node scripts/auditInventoryEffects.js",
    "retry:inventory-effects": "npm run build && node scripts/retryInventoryEffects.js",
    "test:workOrderEngineFunctions": "npm run build && node --test test/workOrderEngineFunctions.test.js",
    "test:completeAssignedJob": "npm run build && node --test test/completeAssignedJob.test.js"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "firebase-functions-test": "^3.4.0",
    "firebase-tools": "13.29.1",
    "typescript": "^5.5.4"
  }
}
